# ============================================
# Laravel Application Configuration
# ============================================

# Project
PROJECT_NAME=laravel-app
APP_NAME=Laravel
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
LOG_CHANNEL=stack

# ============================================
# Database (MySQL)
# ============================================
DB_HOST=db
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# ============================================
# Redis Cache & Queue
# ============================================
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ============================================
# Mail Configuration
# ============================================
MAIL_DRIVER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_FROM_NAME="${APP_NAME}"
MAIL_FROM_ADDRESS=hello@example.com

# ============================================
# Docker Configuration
# ============================================
APP_PORT=8000
DOCKERFILE=Dockerfile
APP_CONTEXT=./

# MySQL Admin (Adminer)
ADMINER_PORT=8888

# Mailhog UI
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ============================================
# Docker Images (Optional)
# ============================================
MYSQL_IMAGE=mysql:8.0
REDIS_IMAGE=redis:7.0-alpine
MAILHOG_IMAGE=mailhog/mailhog:latest
ADMINER_IMAGE=adminer:4.8.1

# ============================================
# Docker Directories
# ============================================
MYSQL_CONFIG_DIR=./.docker/mysql
MYSQL_INIT_DIR=./.docker/mysql/init
